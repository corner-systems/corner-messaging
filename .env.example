# .env
# 서버 위치: ~/sites/messaging.corneropen.com/.env  (chmod 644, 소유자 corner)
# 생성: project-init.sh
#
# 주의: PORT 는 docker-compose.yml 의 environment 가 항상 3000 으로 덮어씁니다.
# 이 파일의 PORT 값은 로컬(컨테이너 밖) 개발용 참고일 뿐 운영 시 무시됩니다.
#
# 로컬 dev 컨테이너의 host 측 포트 (외부 노출 포트) 는 .env 가 아니라
# .env.deploy.local 의 APP_PORT 에서 관리합니다 (up.sh 가 export 해서 docker compose 가 사용).

NODE_ENV=production
PORT=3000

# 데이터베이스
# DATABASE_URL=

# 필요한 환경변수를 추가하세요
